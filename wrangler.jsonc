{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "patent-match",
  "compatibility_date": "2025-09-27",
  "assets": {
    "directory": "public"
  },
  "routes": [
    {
      "pattern": "patent-match.jp/*",
      "zone_name": "patent-match.jp"
    },
    {
      "pattern": "www.patent-match.jp/*",
      "zone_name": "patent-match.jp"
    }
  ]
}
